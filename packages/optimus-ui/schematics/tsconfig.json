{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "moduleResolution": "node",
        "lib": ["ES2022"],
        "outDir": "./dist",
        "rootDir": ".",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "declaration": false,
        "sourceMap": false,
        "types": ["node"]
    },
    "include": ["ng-add/**/*.ts", "migrate-from-primeng/**/*.ts", "utils/**/*.ts"],
    "exclude": ["**/*.spec.ts", "test/**", "dist/**"]
}
